# PostgreSQL connection string. Use the form below for Docker (postgres:16-alpine with user/pass).
# For local postgres with no password: postgresql://postgres@localhost:5432/tcms
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tcms
JWT_SECRET=change-me-in-production
# API port (default 3001). Use 3001 to avoid conflict with other apps on 3000.
PORT=3001
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5001
